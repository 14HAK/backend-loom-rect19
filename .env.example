# ----- Server -----
NODE_ENV=development
PORT=8000
CLIENT_URL=http://localhost:5173

# ----- Database -----
MONGO_URI=mongodb://127.0.0.1:27017/techstore

# ----- Auth -----
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d
COOKIE_EXPIRE_DAYS=7

# ─────────────────────────────────────────────
#  IMAGE STORAGE — change ONE line to switch
#
#  local      → saves to /uploads/ folder (local dev)
#  cloudinary → saves to Cloudinary CDN   (Vercel / production)
# ─────────────────────────────────────────────
IMAGE_STORAGE=local

# ----- Cloudinary (required when IMAGE_STORAGE=cloudinary) -----
# Get from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ----- Stripe (Phase 5) -----
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxx
# Get from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ----- Seeder -----
ADMIN_NAME=Admin User
[email protected]
ADMIN_PASSWORD=Admin@12345
